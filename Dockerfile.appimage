# syntax=docker/dockerfile:1.7

ARG FLUFFYCHAT_BUILDER_IMAGE=ghcr.io/cirruslabs/flutter@sha256:7efb4cd5ef95687924a02cb932dcc27f08450cca92b34a36850dec5292b029d5
FROM ${FLUFFYCHAT_BUILDER_IMAGE}

WORKDIR /app

COPY pubspec.yaml pubspec.lock ./
COPY packages/messie_api/pubspec.yaml packages/messie_api/pubspec.yaml
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

COPY . .

RUN chmod +x scripts/build_linux_appimage.sh

ENTRYPOINT ["bash", "scripts/build_linux_appimage.sh"]
