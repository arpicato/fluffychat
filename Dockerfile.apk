# Build FluffyChat APK (arm64 only for fast builds)
# syntax=docker/dockerfile:1.7
FROM ghcr.io/cirruslabs/flutter:3.41.6

# Install Rust toolchain for native crypto (Vodozemac) — arm64 only
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && . "$HOME/.cargo/env" \
    && rustup target add aarch64-linux-android

ENV PATH="/root/.cargo/bin:${PATH}"
ENV PUB_CACHE=/root/.pub-cache

# Install Android SDK dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-17-jdk-headless \
    && rm -rf /var/lib/apt/lists/*

ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

WORKDIR /app

# Copy dependency files first for caching
COPY pubspec.yaml pubspec.lock ./
COPY packages/ packages/
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

# Copy source
COPY . .

# Ensure the Gradle wrapper uses a portable Linux shebang, LF line endings,
# and executable permissions inside the container.
RUN perl -0pi -e 's/\r\n/\n/g' android/gradlew \
    && sed -i '1s|^#!.*|#!/usr/bin/env bash|' android/gradlew \
    && chmod +x android/gradlew

# Generate signing keystore
RUN keytool -genkeypair -v -keystore android/app/dummy.keystore \
    -alias dummyAlias -keyalg RSA -keysize 2048 -validity 10000 \
    -storepass dummyStorePassword -keypass dummyPassword \
    -storetype JKS \
    -dname "CN=Dummy, OU=Dummy, O=Dummy, L=Dummy, ST=Dummy, C=US"

# Build APK — arm64 only (--target-platform)
RUN --mount=type=cache,target=/root/.pub-cache \
    --mount=type=cache,target=/root/.gradle \
    --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    flutter build apk --release --target-platform android-arm64 -v 2>&1 | tee /tmp/build.log; \
    if [ ! -f /app/build/app/outputs/flutter-apk/app-release.apk ]; then \
      cat /tmp/build.log; exit 1; \
    fi

# Output is at /app/build/app/outputs/flutter-apk/app-release.apk
