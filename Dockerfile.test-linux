# syntax=docker/dockerfile:1.7

# Headless Linux test runner for widget + integration smoke tests.
# Uses the same pinned Flutter base as Dockerfile.linux, plus Xvfb/DBus.
# flutter:3.41.6 linux/amd64
FROM ghcr.io/cirruslabs/flutter@sha256:7efb4cd5ef95687924a02cb932dcc27f08450cca92b34a36850dec5292b029d5

RUN apt-get update && apt-get install -y --no-install-recommends \
    clang llvm lld cmake ninja-build pkg-config \
    libgtk-3-dev liblzma-dev libstdc++-12-dev \
    libsecret-1-dev libjsoncpp-dev libsqlite3-dev \
    libwebkit2gtk-4.1-dev libssl-dev tcl chromium \
    xvfb dbus-x11 xauth mesa-utils libgl1-mesa-dri curl git ca-certificates yq unzip \
    gnome-keyring libsecret-tools \
    && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,id=cargo-install,target=/root/.cargo/install-cache \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

COPY pubspec.yaml pubspec.lock ./
COPY packages/messie_api/pubspec.yaml packages/messie_api/pubspec.yaml
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

COPY . .

RUN --mount=type=cache,target=/root/.pub-cache \
    --mount=type=cache,id=fluffychat-test-dart-tool,target=/app/.dart_tool \
    --mount=type=cache,id=fluffychat-test-build,target=/app/build \
    flutter test --version

CMD ["bash"]
