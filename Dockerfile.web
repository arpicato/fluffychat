# Stage 1: Build FluffyChat web
FROM ghcr.io/cirruslabs/flutter:3.32.0 AS builder

# Install Rust toolchain and wasm-pack
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && . "$HOME/.cargo/env" \
    && rustup target add wasm32-unknown-unknown \
    && cargo install wasm-pack

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    yq unzip curl git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app
COPY . .

# Prepare web (compile Vodozemac WASM, native_imaging, native_executor)
RUN sh scripts/prepare-web.sh

# Build Flutter web release
RUN flutter build web --release --source-maps

# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=builder /app/build/web /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
