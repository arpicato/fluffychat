# Build FluffyChat APK (arm64 only for fast builds)
# syntax=docker/dockerfile:1.7
ARG FLUFFYCHAT_BUILDER_IMAGE=ghcr.io/cirruslabs/flutter:3.41.6
FROM ${FLUFFYCHAT_BUILDER_IMAGE} AS builder

ARG APK_SIGNING_MODE=release
ARG APK_DEV_VERSION_CODE=
ARG APK_DEV_VERSION_NAME=

WORKDIR /app

# Copy dependency files first for caching
COPY pubspec.yaml pubspec.lock ./
COPY packages/ packages/
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

# Copy source
COPY . .

# Ensure the Gradle wrapper uses a portable Linux shebang, LF line endings,
# and executable permissions inside the container.
RUN perl -0pi -e 's/\r\n/\n/g' android/gradlew \
    && sed -i '1s|^#!.*|#!/usr/bin/env bash|' android/gradlew \
    && chmod +x android/gradlew

RUN if [ "$APK_SIGNING_MODE" = "release" ] && [ ! -f android/key.properties ]; then \
      echo "ERROR: android/key.properties is required for upgrade-compatible APK builds." >&2; \
      echo "Use APK_SIGNING_MODE=dev only for persistent local-dev signing or disposable test installs." >&2; \
      exit 1; \
    fi

# Build APK — arm64 only (--target-platform)
RUN --mount=type=cache,target=/root/.pub-cache \
    --mount=type=cache,target=/root/.gradle \
    --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,id=fluffychat-apk-dart-tool,target=/app/.dart_tool \
    --mount=type=cache,id=fluffychat-apk-build,target=/app/build \
    FLUFFY_DEV_VERSION_CODE="$APK_DEV_VERSION_CODE" \
    FLUFFY_DEV_VERSION_NAME="$APK_DEV_VERSION_NAME" \
    flutter build apk --release --target-platform android-arm64 -v 2>&1 | tee /tmp/build.log; \
    if [ ! -f /app/build/app/outputs/flutter-apk/app-release.apk ]; then \
      cat /tmp/build.log; exit 1; \
    fi

FROM alpine:3.20
COPY --from=builder /app/build/app/outputs/flutter-apk/app-release.apk /out/app-release.apk
CMD ["/bin/true"]
