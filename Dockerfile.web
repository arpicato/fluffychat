# syntax=docker/dockerfile:1.7

# Stage 1: Build FluffyChat web
ARG FLUFFYCHAT_BUILDER_IMAGE=ghcr.io/cirruslabs/flutter@sha256:7efb4cd5ef95687924a02cb932dcc27f08450cca92b34a36850dec5292b029d5
FROM ${FLUFFYCHAT_BUILDER_IMAGE} AS builder

ARG FLUFFY_FRONTEND_COMMIT=unknown
ARG FLUFFY_FRONTEND_BUILD_DATE=unknown

WORKDIR /app

# Copy dependency descriptors first so pub resolution stays cached across code changes.
COPY pubspec.yaml pubspec.lock ./
COPY packages/messie_api/pubspec.yaml packages/messie_api/pubspec.yaml
RUN --mount=type=cache,target=/root/.pub-cache \
    flutter pub get

# Copy source after dependency setup.
COPY . .

# Prepare web (compile Vodozemac WASM, native_imaging)
# Cache mounts for Cargo registry/git/target make incremental Rust builds fast.
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,id=vodozemac-target,target=/tmp/vodozemac-target \
    --mount=type=cache,target=/root/.pub-cache \
    --mount=type=cache,id=fluffychat-web-dart-tool,target=/app/.dart_tool \
    --mount=type=cache,id=fluffychat-web-build,target=/app/build \
    set -e; \
    version=$(yq ".dependencies.flutter_vodozemac" < pubspec.yaml | tr -d '"^'); \
    git clone https://github.com/famedly/dart-vodozemac.git -b ${version} .vodozemac; \
    cd .vodozemac; \
    export CARGO_TARGET_DIR=/tmp/vodozemac-target; \
    flutter_rust_bridge_codegen build-web --dart-root dart --rust-root $(readlink -f rust) --release; \
    cd ..; \
    rm -f ./assets/vodozemac/vodozemac_bindings_dart*; \
    mv .vodozemac/dart/web/pkg/vodozemac_bindings_dart* ./assets/vodozemac/; \
    rm -rf .vodozemac; \
    dart compile js ./web/native_executor.dart -o ./web/native_executor.js -m || true; \
    version=$(yq ".dependencies.native_imaging" < pubspec.yaml | tr -d '"^'); \
    curl -L "https://github.com/famedly/dart_native_imaging/releases/download/v${version}/native_imaging.zip" > native_imaging.zip; \
    unzip native_imaging.zip; \
    mv js/* web/; \
    rmdir js; \
    rm native_imaging.zip

# Build Flutter web release
RUN --mount=type=cache,target=/root/.pub-cache \
    --mount=type=cache,id=fluffychat-web-dart-tool,target=/app/.dart_tool \
    --mount=type=cache,id=fluffychat-web-build,target=/app/build \
    set -e; \
    flutter build web --release --source-maps \
      --dart-define=FLUFFY_FRONTEND_COMMIT=${FLUFFY_FRONTEND_COMMIT} \
      --dart-define=FLUFFY_FRONTEND_BUILD_DATE=${FLUFFY_FRONTEND_BUILD_DATE}; \
    rm -rf /tmp/fluffychat-web-build; \
    cp -a /app/build/web /tmp/fluffychat-web-build

# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=builder /tmp/fluffychat-web-build /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
